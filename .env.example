# --- Jira credentials (required for Jira ticket sources) ---
JIRA_EMAIL=your-email@redhat.com
JIRA_PERSONAL_TOKEN=your-atlassian-api-token
JIRA_BASE_URL=https://redhat.atlassian.net

# --- Operator repo (required) ---
REPO_URL=https://github.com/org/operator-name

# --- Cluster / environment (single value or slash-separated list) ---
TARGET_ENV=all                # aws | azure | gcp | bare-metal | on-prem | all
OCP_VERSION=all               # 4.14 | 4.16 | 4.18 | 4.19 | 4.20 | all
SCANNING=yes                  # yes | no  (generate image scanning tests?)
METRICS=yes                   # yes | no  (generate Prometheus metrics tests?)
OLM=yes                       # yes | no  (generate OLM lifecycle tests?)

# --- Automation ---
# Set to "true" to skip the confirmation summary and run fully non-interactive
AUTO_CONFIRM=false
